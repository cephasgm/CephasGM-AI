{
  "name": "cephasgm-ai-backend",
  "version": "6.0.0",
  "description": "CephasGM AI Backend Server - Main API & Agent Runtime",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "prod": "NODE_ENV=production node server.js",
    "deploy": "gcloud app deploy",
    "docker:build": "docker build -t cephasgm-ai-backend .",
    "docker:run": "docker run -p 3000:3000 cephasgm-ai-backend",
    "test": "jest",
    "test:watch": "jest --watch",
    "cluster": "node ../cluster/node-manager.js",
    "agents": "node -e \"console.log('Loading agents...')\"",
    "health": "curl http://localhost:3000/health"
  },
  "dependencies": {
    "express": "^4.18.2",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "dotenv": "^16.3.1",
    "node-fetch": "^2.7.0",
    "pdf-parse": "^1.1.1",
    "busboy": "^1.6.0",
    "multer": "^1.4.5-lts.1",
    "ws": "^8.14.2",
    "socket.io": "^4.7.2",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "uuid": "^9.0.1",
    "@pinecone-database/pinecone": "^2.0.0",
    "mongodb": "^6.3.0",
    "redis": "^4.6.10",
    "bull": "^4.12.0",
    "winston": "^3.11.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "ai",
    "backend",
    "api",
    "express",
    "agent-runtime",
    "multimodal",
    "gpu-cluster"
  ],
  "author": "CephasGM",
  "license": "MIT",
  "phase3": {
    "features": ["Multi-Agent System", "Chat Engine", "Code Interpreter", "Model Host", "Video Generator"]
  },
  "phase4": {
    "features": ["AI Operating System", "Planner Agent", "Research Agent", "Coding Agent", "Automation Agent"]
  },
  "phase5": {
    "features": ["Platform Orchestrator", "Task Queue", "AI Gateway", "Model Router", "GPU Node", "Load Balancer"]
  },
  "phase6": {
    "features": ["AI OS", "Agent Factory", "Node Manager", "GPU Worker", "Training Worker"]
  }
}
