{
  "name": "cephasgm-ai",
  "version": "5.0.0",
  "description": "CephasGM AI Platform - Phase 5: Enterprise AI Infrastructure",
  "main": "api/server.js",
  "scripts": {
    "start": "node api/server.js",
    "dev": "nodemon api/server.js",
    "prod": "NODE_ENV=production node api/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "format": "prettier --write .",
    "cluster:status": "curl http://localhost:5000/api/cluster",
    "metrics": "curl http://localhost:5000/api/metrics",
    "employees": "curl http://localhost:5000/api/employees",
    "models": "curl http://localhost:5000/api/models",
    "health": "curl http://localhost:5000/health"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^6.9.0",
    "node-fetch": "^2.6.7",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.6.0",
    "supertest": "^6.3.3",
    "eslint": "^8.45.0",
    "prettier": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "ai",
    "artificial-intelligence",
    "machine-learning",
    "infrastructure",
    "distributed-systems",
    "microservices",
    "api",
    "llm",
    "agent",
    "autonomous",
    "knowledge-base",
    "vector-database"
  ],
  "author": "CephasGM",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cephasgm/cephasgm-ai.git"
  },
  "bugs": {
    "url": "https://github.com/cephasgm/cephasgm-ai/issues"
  },
  "homepage": "https://cephasgm.ai",
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ]
  },
  "eslintConfig": {
    "extends": ["eslint:recommended"],
    "env": {
      "node": true,
      "jest": true
    }
  }
}
