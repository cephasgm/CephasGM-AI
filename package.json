{
  "name": "cephasgm-ai",
  "version": "6.0.0",
  "description": "CephasGM AI - Complete AI Ecosystem (Phases 1-6)",
  "main": "api/server.js",
  "scripts": {
    "start": "node api/server.js",
    "dev": "nodemon api/server.js",
    "prod": "NODE_ENV=production node api/server.js",
    "frontend": "cd frontend && python3 -m http.server 8000",
    "backend": "node backend/server.js",
    "functions": "cd functions && npm run serve",
    "cluster": "node cluster/node-manager.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "format": "prettier --write .",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "echo 'Frontend is static HTML/JS - no build needed'",
    "build:backend": "cd backend && npm install",
    "deploy": "npm run deploy:frontend && npm run deploy:backend && npm run deploy:functions",
    "deploy:frontend": "echo 'Deploy frontend to GitHub Pages/Vercel'",
    "deploy:backend": "cd backend && npm run deploy",
    "deploy:functions": "cd functions && npm run deploy",
    "phase1": "echo 'Running Phase 1: Basic PWA with Firebase Auth'",
    "phase2": "echo 'Running Phase 2: AI Features with Firebase Functions'",
    "phase3": "echo 'Running Phase 3: Multi-Agent System'",
    "phase4": "echo 'Running Phase 4: AI Operating System'",
    "phase5": "echo 'Running Phase 5: AI Infrastructure Platform'",
    "phase6": "echo 'Running Phase 6: Complete AI Ecosystem'",
    "status": "node -e \"console.log(require('./package.json').description)\""
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "dotenv": "^16.3.1",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "ai",
    "artificial-intelligence",
    "machine-learning",
    "ecosystem",
    "pwa",
    "firebase",
    "multimodal",
    "gpu-cluster",
    "vector-database",
    "knowledge-graph",
    "agent-framework",
    "llm"
  ],
  "author": "CephasGM",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cephasgm/cephasgm-ai.git"
  },
  "bugs": {
    "url": "https://github.com/cephasgm/cephasgm-ai/issues"
  },
  "homepage": "https://cephasgm.ai",
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/frontend/",
      "/functions/"
    ]
  },
  "phase1": {
    "name": "Basic PWA with Firebase Auth",
    "files": ["index.html", "manifest.json", "sw.js", "login-signup.html"]
  },
  "phase2": {
    "name": "AI Features with Firebase Functions",
    "files": ["app.js", "ai.js", "upload.js", "voice.js", "image.js", "memory.js", "agents.js"]
  },
  "phase3": {
    "name": "Multi-Agent System",
    "files": ["backend/agents/", "backend/ai/", "gpu/", "memory/"]
  },
  "phase4": {
    "name": "AI Operating System",
    "files": ["core/", "agents/planner-agent.js", "agents/research-agent.js", "agents/coding-agent.js", "agents/automation-agent.js"]
  },
  "phase5": {
    "name": "AI Infrastructure Platform",
    "files": ["platform/", "cloud/", "cluster/"]
  },
  "phase6": {
    "name": "Complete AI Ecosystem",
    "files": ["ecosystem/", "multimodal/", "learning/"]
  }
}
